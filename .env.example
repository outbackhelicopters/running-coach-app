# Copy to .env for local development. In production (DigitalOcean App
# Platform) these are set as encrypted environment variables instead —
# never commit real values.

# Postgres connection string. DigitalOcean injects this automatically
# when a Managed Database is bound to the app component.
DATABASE_URL=postgres://user:password@localhost:5432/running_coach

# Random secret used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Optional — defaults to 8080, which is what DigitalOcean App Platform expects.
PORT=8080
